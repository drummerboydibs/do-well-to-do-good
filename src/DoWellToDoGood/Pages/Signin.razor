@page "/signin"
@using DoWellToDoGood.Services
@inject AuthService Auth
@inject CryptoService Crypto
@inject EntriesService Store
@inject StatsService Stats
@inject ThemeService Theme
@inject NavigationManager Nav

<PageTitle>@(Auth.IsSignedIn ? "Account" : "Sign in") — Do Well to Do Good</PageTitle>

<div class="mx-auto max-w-md px-6">
    <div class="card space-y-4">
        <img src="icons/icon.svg" alt="" class="mx-auto w-16 h-16 drop-shadow block" width="64" height="64" />

        @if (Auth.IsSignedIn)
        {
            <div class="space-y-1">
                <h1 class="text-center">Account</h1>
                <p class="text-muted text-center m-0">@Auth.Email</p>
                @if (_createdAt.HasValue || _lastSignIn.HasValue)
                {
                    <div class="flex flex-col items-center gap-0.5">
                        @if (_createdAt.HasValue)
                        {
                            <p class="text-xs text-muted m-0">Member since @_createdAt.Value.ToLocalTime().ToString("MMMM d, yyyy")</p>
                        }
                        @if (_lastSignIn.HasValue)
                        {
                            <p class="text-xs text-muted m-0">Last login @_lastSignIn.Value.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</p>
                        }
                    </div>
                }
            </div>

            <section aria-labelledby="stats-heading" class="space-y-3">
                <h2 id="stats-heading" class="text-base font-bold m-0">Your journey</h2>
                @if (_statsLoading)
                {
                    <p class="text-muted text-sm m-0" role="status">Counting…</p>
                }
                else
                {
                    <div class="grid grid-cols-3 gap-3">
                        <div class="stat">
                            <span class="stat-num">@(_savedCount?.ToString() ?? "—")</span>
                            <span class="stat-label">Saved @(_savedCount == 1 ? "entry" : "entries")</span>
                        </div>
                        <div class="stat">
                            <span class="stat-num">@_shoutCount</span>
                            <span class="stat-label">Shouted into the wind (from this device)</span>
                        </div>
                        <div class="stat">
                            <span class="stat-num">@(_streak > 0 ? $"🔥 {_streak}" : "0")</span>
                            <span class="stat-label">Day streak</span>
                        </div>
                    </div>
                    @if (_streak > 0)
                    {
                        <p class="text-muted text-sm m-0">
                            @_streak consecutive @(_streak == 1 ? "day" : "days") of showing up for yourself — keep it going.
                        </p>
                    }
                    @if (_statsError)
                    {
                        <p class="text-muted text-sm m-0">Couldn't reach your saved entries just now; the count above may be incomplete.</p>
                    }
                }
            </section>

            <div class="space-y-3">
                <section aria-labelledby="appearance-heading" class="space-y-2">
                    <h2 id="appearance-heading" class="text-base font-bold m-0">Appearance</h2>
                    <fieldset class="segmented">
                        <legend class="sr-only">Color theme</legend>
                        @foreach (var opt in _themeOptions)
                        {
                            <label class="segmented-option">
                                <input type="radio" name="theme" class="sr-only" value="@opt.Value"
                                       checked="@(Theme.Current == opt.Value)"
                                       @onchange="() => SetTheme(opt.Value)" />
                                <span aria-hidden="true">@opt.Icon</span> @opt.Label
                            </label>
                        }
                    </fieldset>
                </section>

                <div class="space-y-3">
                    <a class="btn btn-primary btn-block" href="journal">Start writing</a>
                    <a class="btn btn-block" href="entries">Open my journal</a>
                    <button class="btn btn-ghost btn-block" @onclick="SignOut">Sign out</button>
                </div>
            </div>
        }
        else if (_sent)
        {
            <h1 class="text-center">Check your email</h1>
            <p class="text-muted text-center">
                We sent a one-time sign-in link from Supabase to <strong>@_email</strong>. Open it on this device
                and you'll land back here, signed in.
            </p>
            <p class="text-muted text-sm text-center">It can take a minute to arrive. Check spam if it's shy.</p>
            <button class="btn btn-ghost btn-block" @onclick="() => _sent = false">Use a different email</button>
        }
        else
        {
            <h1 class="text-center">Welcome</h1>
            <p class="text-muted text-center">
                Enter your email and we'll send you a one-time sign-in link.
                No password to remember — or for anyone to steal.
            </p>
            <div class="field">
                <label class="label" for="email">Email</label>
                <input id="email" class="input" type="email" inputmode="email" autocomplete="email"
                       @bind="_email" placeholder="you@example.com" />
            </div>
            @if (_error is not null)
            {
                <p class="text-sm font-semibold m-0" style="color:var(--color-danger)" role="alert">@_error</p>
            }
            <button class="btn btn-primary btn-block" disabled="@_busy" @onclick="Send">
                @(_busy ? "Sending…" : "Email me a sign-in link")
            </button>
            <p class="text-muted text-sm text-center m-0">
                New here? The same link creates your free account. Or
                <a href="journal">continue as a guest</a> — nothing saved, ever.
            </p>
        }
    </div>
</div>

@code {
    private string _email = "";
    private string? _error;
    private bool _busy, _sent;

    private bool _statsLoading = true;
    private bool _statsError;
    private int? _savedCount;
    private int _shoutCount;
    private int _streak;
    private DateTimeOffset? _createdAt;
    private DateTimeOffset? _lastSignIn;

    private record ThemeOption(string Value, string Label, string Icon);
    private readonly ThemeOption[] _themeOptions =
    {
        new(ThemeService.Light, "Light", "☀️"),
        new(ThemeService.Dark, "Dark", "🌙"),
        new(ThemeService.System, "System", "🖥️"),
    };

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsSignedIn) await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        _statsLoading = true;
        var days = new List<DateOnly>();

        // Shouts are local (count + dates only — never any words).
        try
        {
            var (count, shoutDays) = await Stats.GetShoutsAsync();
            _shoutCount = count;
            days.AddRange(shoutDays);
        }
        catch { _shoutCount = 0; }

        // Saved entries come from the server as timestamps — no decryption needed.
        try
        {
            var timestamps = await Store.ListEntryTimestampsAsync();
            _savedCount = timestamps.Count;
            days.AddRange(timestamps.Select(t => DateOnly.FromDateTime(t.LocalDateTime)));
        }
        catch
        {
            _savedCount = null; // shown as "—"
            _statsError = true;
        }

        _streak = StatsService.CurrentStreak(days);

        try { (_createdAt, _lastSignIn) = await Auth.GetUserMetaAsync(); }
        catch { }

        _statsLoading = false;
    }

    private async Task SetTheme(string preference) => await Theme.SetAsync(preference);

    private async Task Send()
    {
        _error = null;
        var email = _email.Trim();
        if (email.Length < 5 || !email.Contains('@') || !email.Contains('.'))
        {
            _error = "Please enter a valid email address.";
            return;
        }
        _busy = true;
        try
        {
            var (ok, err) = await Auth.SendMagicLinkAsync(email);
            if (ok) _sent = true;
            else _error = err;
        }
        finally { _busy = false; }
    }

    private async Task SignOut()
    {
        await Crypto.LockAsync();   // wipe the encryption key from memory
        await Auth.SignOutAsync();
        Nav.NavigateTo("");
    }
}
