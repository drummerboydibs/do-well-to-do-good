@page "/signin"

<PageTitle>Sign in — Do Well to Do Good</PageTitle>

<div class="mx-auto max-w-md px-6">
    <div class="card text-center space-y-4">
        <img src="icons/icon.svg" alt="" class="mx-auto w-16 h-16 drop-shadow" width="64" height="64" />
        <h1>Welcome</h1>
        <p class="text-muted">
            Passwordless sign-in with a magic link is coming very soon — you’ll get a one-time link by email,
            so there’s no password to remember or store.
        </p>
        <p class="text-muted">In the meantime, you can start writing right now as a guest.</p>
        <a class="btn btn-primary btn-lg btn-block" href="journal">Continue as a guest</a>
        <p><a class="text-sm" href="">← Back home</a></p>
    </div>
</div>
