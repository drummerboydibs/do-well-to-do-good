@page "/resources"

<PageTitle>Resources &amp; Support — Do Well to Do Good</PageTitle>

<div class="overflow-x-clip">

    @* ===================== Header ===================== *@
    <section class="mx-auto max-w-3xl px-6 pt-4 pb-6 text-center space-y-4">
        <h1>Resources &amp; Support</h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
            Whether you need immediate support or want to build long-term wellness, these vetted resources are here for you.
        </p>
    </section>

    @* ===================== Crisis / Emergency ===================== *@
    <section class="mx-auto max-w-5xl px-6 pb-6">
        <div class="card space-y-6" style="border-color:var(--color-emo-angry); border-width:2px">

            <div class="flex items-start gap-4">
                <span class="inline-flex items-center justify-center w-11 h-11 rounded-full shrink-0 mt-0.5"
                      style="color:var(--color-danger); background:var(--color-emo-angry-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <p class="text-sm font-semibold m-0 mb-1" style="color:var(--color-danger)">If you need help right now</p>
                    <h2 class="mb-1">Crisis &amp; Emergency Support</h2>
                    <p class="text-muted m-0">
                        If someone is in immediate danger, call <strong>911</strong>. The services below are free, confidential, and available 24/7.
                    </p>
                </div>
            </div>

            <div class="grid sm:grid-cols-3 gap-4">

                <article class="card-soft space-y-3">
                    <h3 class="text-base font-semibold m-0">988 Suicide &amp; Crisis Lifeline</h3>
                    <p class="text-sm text-muted m-0">
                        Free, confidential support for anyone in distress — call, text, or chat online. Available 24/7.
                    </p>
                    <div class="flex flex-col gap-2 pt-1">
                        <a class="btn btn-primary" href="tel:988">Call or text <strong>988</strong></a>
                        <a class="btn" href="https://988lifeline.org" target="_blank" rel="noopener noreferrer">988lifeline.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </article>

                <article class="card-soft space-y-3">
                    <h3 class="text-base font-semibold m-0">Crisis Text Line</h3>
                    <p class="text-sm text-muted m-0">
                        Prefer to type? Trained crisis counselors respond in real time, 24/7 — no call needed.
                    </p>
                    <div class="flex flex-col gap-2 pt-1">
                        <p class="font-semibold m-0">Text <strong>HOME</strong> to <strong>741741</strong></p>
                        <a class="btn" href="https://www.crisistextline.org" target="_blank" rel="noopener noreferrer">crisistextline.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </article>

                <article class="card-soft space-y-3">
                    <h3 class="text-base font-semibold m-0">SAMHSA National Helpline</h3>
                    <p class="text-sm text-muted m-0">
                        Free, confidential mental health and substance use treatment referrals. 24/7, in English and Spanish.
                    </p>
                    <div class="flex flex-col gap-2 pt-1">
                        <a class="btn btn-primary" href="tel:+18006624357">Call 1-800-662-4357</a>
                        <a class="btn" href="https://www.samhsa.gov/find-help/national-helpline" target="_blank" rel="noopener noreferrer">samhsa.gov <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </article>

            </div>
        </div>
    </section>

    @* ===================== Gambling ===================== *@
    <section class="mx-auto max-w-5xl px-6 py-6">
        <h2 class="mb-6">Gambling Support</h2>
        <div class="grid sm:grid-cols-3 gap-5">

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-secondary); background:var(--color-secondary-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.85 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.96 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>National Problem Gambling Helpline</h3>
                    <p class="text-muted m-0">Free, confidential 24/7 helpline for problem gamblers and their families — call, text, or chat.</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn btn-primary" href="tel:+18005224700">Call 1-800-522-4700</a>
                        <a class="btn" href="https://www.ncpgambling.org" target="_blank" rel="noopener noreferrer">ncpgambling.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-secondary); background:var(--color-secondary-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Gamblers Anonymous</h3>
                    <p class="text-muted m-0">Free peer-support meetings, in-person and online, for anyone affected by a gambling problem.</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn" href="https://www.gamblersanonymous.org" target="_blank" rel="noopener noreferrer">gamblersanonymous.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-secondary); background:var(--color-secondary-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Gam-Anon</h3>
                    <p class="text-muted m-0">Support for spouses, families, and friends of people with gambling problems — meetings worldwide.</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn" href="https://www.gam-anon.org" target="_blank" rel="noopener noreferrer">gam-anon.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

        </div>
    </section>

    @* ===================== Addiction & Recovery ===================== *@
    <section class="mx-auto max-w-5xl px-6 py-6">
        <h2 class="mb-6">Addiction &amp; Recovery</h2>
        <div class="grid sm:grid-cols-2 gap-5">

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-emo-calm); background:var(--color-emo-calm-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Alcoholics Anonymous</h3>
                    <p class="text-muted m-0">Free peer-support meetings worldwide for anyone with a desire to stop drinking — in-person and online.</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn" href="https://www.aa.org" target="_blank" rel="noopener noreferrer">aa.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                        <p class="text-sm text-muted m-0">For families &amp; friends: <a href="https://al-anon.org" target="_blank" rel="noopener noreferrer">Al-Anon (al-anon.org)<span class="sr-only"> (opens in a new tab)</span></a></p>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-emo-calm); background:var(--color-emo-calm-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Narcotics Anonymous</h3>
                    <p class="text-muted m-0">Free peer-support meetings for people recovering from drug addiction — thousands of in-person and online meetings available.</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn" href="https://www.na.org" target="_blank" rel="noopener noreferrer">na.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                        <p class="text-sm text-muted m-0">For families &amp; friends: <a href="https://www.nar-anon.org" target="_blank" rel="noopener noreferrer">Nar-Anon (nar-anon.org)<span class="sr-only"> (opens in a new tab)</span></a></p>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-emo-calm); background:var(--color-emo-calm-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>SMART Recovery</h3>
                    <p class="text-muted m-0">A science-based, secular alternative to 12-step programs — uses cognitive-behavioral tools for any addiction, including alcohol, drugs, and gambling.</p>
                    <div class="mt-3">
                        <a class="btn" href="https://www.smartrecovery.org" target="_blank" rel="noopener noreferrer">smartrecovery.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-emo-calm); background:var(--color-emo-calm-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Partnership to End Addiction</h3>
                    <p class="text-muted m-0">Resources and a free helpline for families navigating a loved one's drug or alcohol use — compassionate guidance, not judgment.</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn btn-primary" href="tel:+18553784373">Call 1-855-378-4373</a>
                        <a class="btn" href="https://drugfree.org" target="_blank" rel="noopener noreferrer">drugfree.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

        </div>
    </section>

    @* ===================== Find a Therapist ===================== *@
    <section class="mx-auto max-w-5xl px-6 py-6">
        <h2 class="mb-2">Find a Therapist</h2>
        <p class="text-muted mb-6">Professional therapy is one of the most effective tools for long-term mental wellness. These directories make it easier to find someone who fits your needs and budget.</p>
        <div class="grid sm:grid-cols-2 gap-5">

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-primary); background:var(--color-primary-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Psychology Today</h3>
                    <p class="text-muted m-0">The most widely used therapist directory in the US. Search by location, insurance, specialty, and more.</p>
                    <div class="mt-3">
                        <a class="btn" href="https://www.psychologytoday.com/us/therapists" target="_blank" rel="noopener noreferrer">Find a therapist <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-primary); background:var(--color-primary-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>SAMHSA Treatment Locator</h3>
                    <p class="text-muted m-0">Official government tool to find local mental health and substance use treatment facilities near you.</p>
                    <div class="mt-3">
                        <a class="btn" href="https://findtreatment.gov" target="_blank" rel="noopener noreferrer">findtreatment.gov <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-brand-green); background:var(--color-emo-disgust-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Open Path Collective</h3>
                    <p class="text-muted m-0">A nonprofit network of therapists offering sessions on a sliding scale — making therapy more accessible for those in financial need.</p>
                    <div class="mt-3">
                        <a class="btn" href="https://openpathcollective.org" target="_blank" rel="noopener noreferrer">openpathcollective.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:var(--color-brand-green); background:var(--color-emo-disgust-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>TherapyDen</h3>
                    <p class="text-muted m-0">A therapist directory focused on finding affirming, inclusive care — searchable by identity, specialty, and more.</p>
                    <div class="mt-3">
                        <a class="btn" href="https://www.therapyden.com" target="_blank" rel="noopener noreferrer">therapyden.com <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

        </div>
    </section>

    @* ===================== Mental Health Organizations ===================== *@
    <section class="mx-auto max-w-5xl px-6 py-6">
        <h2 class="mb-6">Mental Health Organizations</h2>
        <div class="grid sm:grid-cols-2 gap-5">

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:#b5832f; background:var(--color-emo-happy-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>NAMI — National Alliance on Mental Illness</h3>
                    <p class="text-muted m-0">The largest mental health advocacy organization in the US, offering education, support groups, and a free HelpLine (M–F, 10am–10pm ET).</p>
                    <div class="flex flex-col gap-2 mt-3">
                        <a class="btn btn-primary" href="tel:+18009506264">Call 1-800-950-6264</a>
                        <a class="btn" href="https://www.nami.org/help" target="_blank" rel="noopener noreferrer">nami.org/help <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

            <article class="card flex gap-4 items-start">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                      style="color:#b5832f; background:var(--color-emo-happy-soft)" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                </span>
                <div class="min-w-0">
                    <h3>Mental Health America</h3>
                    <p class="text-muted m-0">A leading community-based nonprofit offering mental health screening tools, resources, and advocacy for all Americans.</p>
                    <div class="mt-3">
                        <a class="btn" href="https://www.mhanational.org" target="_blank" rel="noopener noreferrer">mhanational.org <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
                    </div>
                </div>
            </article>

        </div>
    </section>

    @* ===================== International ===================== *@
    <section class="mx-auto max-w-5xl px-6 py-6">
        <div class="card flex gap-4 items-start">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full shrink-0"
                  style="color:var(--color-brand-blue); background:var(--color-emo-sad-soft)" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="2" y1="12" x2="22" y2="12" />
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
            </span>
            <div class="min-w-0">
                <h2 class="mb-2">Outside the US?</h2>
                <p class="text-muted m-0 mb-4">
                    Find A Helpline maintains a free, searchable directory of crisis lines, mental health services, and support organizations in countries around the world.
                </p>
                <a class="btn" href="https://findahelpline.com" target="_blank" rel="noopener noreferrer">findahelpline.com <span aria-hidden="true">→</span><span class="sr-only"> (opens in a new tab)</span></a>
            </div>
        </div>
    </section>

    @* ===================== Disclaimer ===================== *@
    <section class="mx-auto max-w-3xl px-6 py-8">
        <p class="text-muted text-sm text-center">
            These resources are provided for informational purposes only and are not a substitute for professional medical advice.
            In a medical or psychiatric emergency, call <strong>911</strong>.
        </p>
    </section>

</div>
